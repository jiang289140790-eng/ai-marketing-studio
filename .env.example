# Frontend public runtime
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
VITE_APP_BASE_PATH=/ai-marketing-studio/
GITHUB_PAGES_BASE=/ai-marketing-studio/

# Local deployment checks
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
GITHUB_TOKEN=your-github-token

# Supabase Edge Function secrets only. Do not expose these in frontend builds.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TELEGRAM_ADMIN_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=@your_channel_or_chat_id
TELEGRAM_WEBHOOK_URL=https://your-project-ref.supabase.co/functions/v1/platform/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
TELEGRAM_TRACKING_BASE_URL=https://your-project-ref.supabase.co/functions/v1/platform
PLATFORM_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/platform
TRACKING_EVENT_SECRET=your-tracking-event-secret

# Future AI provider secrets
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
QWEN_API_KEY=your-qwen-api-key
AI_GATEWAY_DEFAULT_MODEL=deepseek-chat
AI_GATEWAY_TIMEOUT_MS=60000
OPENAI_INPUT_COST_PER_1K=0
OPENAI_OUTPUT_COST_PER_1K=0
ANTHROPIC_INPUT_COST_PER_1K=0
ANTHROPIC_OUTPUT_COST_PER_1K=0
DEEPSEEK_INPUT_COST_PER_1K=0
DEEPSEEK_OUTPUT_COST_PER_1K=0

# Future social platform secrets
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=https://your-domain.example/auth/x/callback
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_BEARER_TOKEN=your-x-bearer-token
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=https://your-project-ref.supabase.co/functions/v1/platform?platform=Instagram
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=https://your-project-ref.supabase.co/functions/v1/platform?platform=YouTube
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=https://your-project-ref.supabase.co/functions/v1/platform?platform=TikTok
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_REDIRECT_URI=https://your-project-ref.supabase.co/functions/v1/platform?platform=Discord

# Media Gateway / self-hosted ComfyUI runtime
COMFYUI_BASE_URL=https://your-comfyui-host
COMFYUI_API_KEY=your-comfyui-api-key-if-needed
COMFYUI_TIMEOUT_MS=60000
COMFYUI_POLL_INTERVAL_MS=2000
COMFYUI_MAX_POLL_MS=300000
