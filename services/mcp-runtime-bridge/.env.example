MCP_RUNTIME_BRIDGE_HOST=0.0.0.0
MCP_RUNTIME_BRIDGE_PORT=8787

# Shared HMAC secret. Must match Supabase Edge Function secret OPS_MCP_BRIDGE_SECRET.
OPS_MCP_BRIDGE_SECRET=replace-with-long-random-secret

# Supabase server-side access. Never expose service role key to GitHub Pages.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local or deployed AI Marketing Studio MCP server directory/command.
MARKETING_STUDIO_MCP_DIR=/app/mcp/marketing-studio
MARKETING_STUDIO_MCP_COMMAND=node
MARKETING_STUDIO_MCP_ARGS=server.js

# Safe default: execute_publish always dry-runs unless this is explicitly true.
ALLOW_REAL_PUBLISH=false

# Optional providers used by the MCP tools.
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
AUTODL_API_BASE=
AUTODL_API_KEY=
COMFYUI_BASE_URL=
X_MCP_ENABLED=false
